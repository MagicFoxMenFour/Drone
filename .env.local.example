# Admin panel
ADMIN_LOGIN=admin
ADMIN_PASSWORD=your_secure_password_here
ADMIN_SESSION_SECRET=not_used_in_sqlite_mode

# Database (for Amvera, will be in /data/)
DB_PATH=/data/app.db

# Email configuration (optional)
RESEND_API_KEY=
RESEND_FROM=
LEADS_TO_EMAIL=

# Server
PORT=3000
NODE_ENV=development

# Legacy (if using Supabase)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
